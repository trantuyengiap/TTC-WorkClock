[Unit]
Description=TTC WorkClock Celery Worker
After=network.target postgresql.service redis-server.service ttc-workclock-api.service
Wants=postgresql.service redis-server.service

[Service]
Type=simple
User=ttc-workclock
Group=ttc-workclock
WorkingDirectory=/opt/ttc-workclock/backend
EnvironmentFile=/opt/ttc-workclock/.env
Environment=PYTHONPATH=/opt/ttc-workclock/backend
ExecStart=/opt/ttc-workclock/backend/.venv/bin/celery -A app.services.scheduler.celery_app.celery_app worker --loglevel=info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
